PORT=4000
HOST=0.0.0.0

# Optional explicit Python runtime path for ML worker.
# If omitted, server auto-detects common local venv locations.
# PYTHON_BIN=C:/path/to/python.exe

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Demo behavior
DEMO_MODE=true
SMS_MAX_RETRIES=2
