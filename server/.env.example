PORT=4000
HOST=0.0.0.0

# Optional explicit Python runtime path for ML worker.
# If omitted, server auto-detects common local venv locations.
# PYTHON_BIN=C:/path/to/python.exe

# Strict backend gating thresholds (0.0 - 1.0)
# fall_prob below FALL_GATE_MIN => NO_FALL
# false_prob at/above FALSE_GATE_MIN => FALSE_ALARM
# otherwise fall_prob must reach REAL_FALL_MIN to emit REAL_FALL
FALL_GATE_MIN=0.15
REAL_FALL_MIN=0.55
FALSE_GATE_MIN=0.76

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Demo behavior
DEMO_MODE=true
SMS_MAX_RETRIES=2
