{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "description": "Starter Express server configured for Node.js and Bun",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "bun --watch src/index.js",
    "dev:node": "nodemon src/index.js",
    "start": "node src/index.js",
    "start:bun": "bun src/index.js"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
