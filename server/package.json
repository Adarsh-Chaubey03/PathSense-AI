{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "description": "Starter Express server configured for Node.js and Bun",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "bun --watch src/index.js",
    "dev:node": "nodemon src/index.js",
    "start": "bun --watch src/index.js",
    "start:bun": "bun src/index.js",
    "build": "tsc",
    "dev:ts": "bun --watch src/index.ts"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "twilio": "^5.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.0.0",
    "@types/twilio": "^3.19.2",
    "nodemon": "^3.1.14",
    "typescript": "^5.7.0"
  }
}
